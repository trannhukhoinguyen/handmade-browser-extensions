{
  "manifest_version": 3,
  "name": "Autofill Tour Form",
  "version": "1.0",
  "description": "Autofill AntD Vue form",

  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "permissions": ["scripting", "activeTab"],

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],

  "commands": {
    "autofill-form": {
      "suggested_key": {
        "default": "Alt+Shift+F"
      },
      "description": "Autofill form"
    }
  }
}
