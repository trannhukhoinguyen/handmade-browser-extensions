{
  "manifest_version": 3,
  "name": "Auto Fill AntD Table",
  "version": "1.0",
  "description": "Tự động điền điểm tối đa cho bảng đánh giá (nhấn Alt + Shift + F)",

  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "permissions": ["activeTab", "scripting"],
  "action": {
    "default_title": "Click để điền điểm (nhấn Alt + Shift + F)",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}
